generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  bike      String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rides     Ride[]
  routes    Route[]
}

model Ride {
  id          String   @id @default(cuid())
  title       String
  description String?
  distance    Float    @default(0)
  duration    Int      @default(0)    // seconds
  avgSpeed    Float    @default(0)    // km/h
  maxSpeed    Float    @default(0)    // km/h
  elevation   Float    @default(0)    // meters gained
  isPublic    Boolean  @default(true)
  isLive      Boolean  @default(false)
  trackData   String                  // JSON: array of [lat, lng, alt, timestamp]
  startLat    Float?
  startLng    Float?
  endLat      Float?
  endLng      Float?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Route {
  id          String   @id @default(cuid())
  title       String
  description String?
  distance    Float    @default(0)
  waypoints   String                 // JSON: array of {lat, lng}
  routeData   String?                // JSON: full polyline coordinates
  category    String   @default("scenic") // scenic, twisty, offroad, city
  difficulty  String   @default("medium") // easy, medium, hard
  isPublic    Boolean  @default(true)
  likes       Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
