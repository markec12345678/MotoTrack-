generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  bike      String?
  bio       String?
  fuelCapacity    Float?    @default(15.0)   // liters
  fuelConsumption Float?    @default(5.5)    // L/100km
  currentFuel     Float?    @default(15.0)   // liters currently in tank
  lastRefuelAt    DateTime?
  iceName1        String?           // ICE contact 1 name (In Case of Emergency)
  icePhone1       String?           // ICE contact 1 phone
  iceName2        String?           // ICE contact 2 name
  icePhone2       String?           // ICE contact 2 phone
  bloodType       String?           // Blood type (e.g., "A+", "O-")
  allergies       String?           // Known allergies
  parkedLat       Float?              // latitude where motorcycle is parked
  parkedLng       Float?              // longitude where motorcycle is parked
  parkedAt        DateTime?           // when the motorcycle was parked
  parkedNote      String?             // optional note about parking spot
  speedLimit      Int?     @default(90)    // user's preferred speed limit (km/h) for alerts
  speedAlertEnabled Boolean? @default(true)  // whether speed alerts are enabled
  speedAlertSound   Boolean? @default(true)  // whether to play sound on alert
  currentMileage   Int?     @default(0)      // odometer reading in km
  // Settings fields
  unitSystem       String?  @default("metric")  // metric (km) or imperial (miles)
  autoPauseEnabled Boolean? @default(true)     // auto-pause when speed < threshold
  autoPauseSpeedThreshold Float? @default(5.0) // km/h - below this = paused
  hideStartEnd     Boolean? @default(false)    // privacy: hide start/end of rides
  wakelockEnabled  Boolean? @default(true)     // keep screen on during tracking
  avoidTolls       Boolean? @default(false)    // avoid toll roads in routing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rides        Ride[]
  routes       Route[]
  comments     Comment[]
  likes        Like[]
  pois         Poi[]
  achievements Achievement[]
  communities CommunityMember[]
  hazards     Hazard[]
  notifications     Notification[]
  sentNotifications Notification[] @relation("SentNotifications")
  requestedFriends  Friendship[]  @relation("RequestedFriends")
  receivedFriends   Friendship[]  @relation("ReceivedFriends")
  sosAlerts    SosAlert[]
  photos       Photo[]
  roadRatings  RoadRating[]
  trips        Trip[]
  expenses     Expense[]
  reminders    MaintenanceReminder[]
  createdGroupRides       GroupRide[]         @relation("GroupRideCreator")
  groupRideParticipations GroupRideParticipant[]
  liveTrackingSessions    LiveTrackingSession[]
  crashEvents             CrashEvent[]
  leanAngleSessions       LeanAngleSession[]
  gpxImports              GpxImport[]
  createdChallenges       Challenge[]
  challengeParticipations ChallengeParticipant[]
  mapStyleConfig          MapStyleConfig?
  userPoints              UserPoints?
  pointsTransactions      PointsTransaction[]
  offlineMaps             OfflineMap[]
  favorites               Favorite[]
  socialActivities        SocialActivity[]
  privacyZones            PrivacyZone[]
}

model Ride {
  id          String   @id @default(cuid())
  title       String
  description String?
  distance    Float    @default(0)
  duration    Int      @default(0)    // seconds
  avgSpeed    Float    @default(0)    // km/h
  maxSpeed    Float    @default(0)    // km/h
  elevation   Float    @default(0)    // meters gained
  isPublic    Boolean  @default(true)
  isLive      Boolean  @default(false)
  trackData   String                  // JSON: array of [lat, lng, alt, timestamp]
  startLat    Float?
  startLng    Float?
  endLat      Float?
  endLng      Float?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id])
  photos      Photo[]
  favorites   Favorite[]
}

model Route {
  id          String   @id @default(cuid())
  title       String
  description String?
  distance    Float    @default(0)
  waypoints   String                 // JSON: array of {lat, lng}
  routeData   String?                // JSON: full polyline coordinates
  category    String   @default("scenic") // scenic, twisty, offroad, city, snowmobile, racetrack
  difficulty  String   @default("medium") // easy, medium, hard
  isPublic    Boolean  @default(true)
  likes       Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
  likesRel    Like[]
  photos      Photo[]
  favorites   Favorite[]
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rideId    String?
  ride      Ride?    @relation(fields: [rideId], references: [id])
  routeId   String?
  route     Route?   @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, routeId])
}

model Poi {
  id          String   @id @default(cuid())
  name        String
  type        String   // gas_station, restaurant, biker_spot, parking, hotel, mechanic, camping, viewpoint, snowmobile, racetrack
  lat         Float
  lng         Float
  description String?
  rating      Float    @default(0)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  type        String   // achievement type key
  title       String
  description String
  icon        String   // emoji
  earnedAt    DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  avatar      String?    // emoji or icon
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     CommunityMember[]
  rides       Ride[]
}

model CommunityMember {
  id          String   @id @default(cuid())
  role        String   @default("member")  // admin, moderator, member
  joinedAt    DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  communityId String
  community   Community @relation(fields: [communityId], references: [id])

  @@unique([userId, communityId])
}

model Hazard {
  id          String   @id @default(cuid())
  type        String   // speed_camera, rockfall, slippery, wildlife, construction, speed_limit, accident
  name        String
  description String?
  lat         Float
  lng         Float
  expiresAt   DateTime?  // when the hazard is no longer valid
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Friendship {
  id          String   @id @default(cuid())
  status      String   @default("pending")  // pending, accepted, blocked
  requesterId String
  requester   User     @relation("RequestedFriends", fields: [requesterId], references: [id])
  addresseeId String
  addressee   User     @relation("ReceivedFriends", fields: [addresseeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String   // like, comment, achievement, friend_request, community_join, hazard_nearby
  title      String
  message    String
  read       Boolean  @default(false)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fromUserId String?
  fromUser   User?    @relation("SentNotifications", fields: [fromUserId], references: [id])
  relatedId  String?  // ID of related entity (ride, route, community, etc.)
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model SosAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  lat        Float
  lng        Float
  type       String   @default("manual") // manual, crash_detected, no_movement
  status     String   @default("active") // active, resolved, false_alarm
  message    String?
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, status])
}

model Photo {
  id        String   @id @default(cuid())
  url       String   // URL to the image (base64 data URLs for simplicity)
  caption   String?  // Optional caption
  rideId    String?
  ride      Ride?    @relation(fields: [rideId], references: [id])
  routeId   String?
  route     Route?   @relation(fields: [routeId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([rideId])
  @@index([routeId])
}

model RoadRating {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  rating    Int      // 1-5 (1=very bad, 5=excellent)
  surface   String   // asphalt, gravel, dirt, mixed
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([lat, lng])
}

model Trip {
  id            String    @id @default(cuid())
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  days          Int       @default(1)
  totalDistance Float     @default(0)
  isPublic      Boolean   @default(true)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tripDays      TripDay[]
}

model TripDay {
  id            String   @id @default(cuid())
  dayNumber     Int
  title         String
  startLat      Float
  startLng      Float
  endLat        Float
  endLng        Float
  waypoints     String   // JSON: array of {lat, lng}
  distance      Float    @default(0)
  duration      Int      @default(0)
  notes         String?
  accommodation String?
  fuelStop      Boolean  @default(false)
  tripId        String
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // fuel, maintenance, insurance, parts, toll, parking, other
  amount      Float    // in EUR
  date        DateTime @default(now())
  description String?
  mileage     Int?     // odometer reading
  createdAt   DateTime @default(now())

  @@map("expenses")
}

model MaintenanceReminder {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String   // oil_change, tire_change, chain_service, brake_service, filter_change, inspection, custom
  title         String
  nextMileage   Int?     // next service at this km
  nextDate      DateTime? // next service by this date
  intervalKm    Int?     // repeat every X km
  intervalDays  Int?     // repeat every X days
  completed     Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@map("maintenance_reminders")
}

model GroupRide {
  id            String    @id @default(cuid())
  title         String
  description   String?
  creatorId     String
  creator       User      @relation("GroupRideCreator", fields: [creatorId], references: [id])
  date          DateTime
  meetingLat    Float
  meetingLng    Float
  meetingPlace  String    // name of meeting spot
  destinationLat Float?
  destinationLng  Float?
  destinationPlace String?
  maxRiders     Int       @default(10)
  category      String    @default("scenic") // scenic, twisty, offroad, city
  status        String    @default("upcoming") // upcoming, active, completed, cancelled
  createdAt     DateTime  @default(now())

  participants  GroupRideParticipant[]

  @@map("group_rides")
}

model GroupRideParticipant {
  id          String   @id @default(cuid())
  groupRideId String
  groupRide   GroupRide @relation(fields: [groupRideId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  status      String   @default("joined") // joined, maybe, declined
  joinedAt    DateTime @default(now())

  @@unique([groupRideId, userId])
  @@map("group_ride_participants")
}

// ==========================================
// NEW MODELS - Top App Features
// ==========================================

// Feature 4: Live Tracking - share real-time location
model LiveTrackingSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  rideId      String?                     // optional link to a ride
  lat         Float
  lng         Float
  speed       Float    @default(0)         // km/h
  heading     Float    @default(0)         // degrees
  shareToken  String   @unique             // public token for sharing link
  isActive    Boolean  @default(true)
  lastPingAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  viewers     LiveTrackingViewer[]

  @@index([userId, isActive])
  @@map("live_tracking_sessions")
}

model LiveTrackingViewer {
  id          String   @id @default(cuid())
  sessionId   String
  session     LiveTrackingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  viewerName  String?                     // optional name of viewer
  viewedAt    DateTime @default(now())

  @@index([sessionId])
  @@map("live_tracking_viewers")
}

// Feature 5: Crash Detection - automatic crash detection logs
model CrashEvent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  lat           Float
  lng           Float
  gForce        Float    // detected g-force
  speedBefore   Float    @default(0)  // km/h before crash
  detectedAt    DateTime @default(now())
  alertSent     Boolean  @default(false) // was emergency alert sent
  alertSentTo   String?  // JSON: array of contact IDs notified
  status        String   @default("detected") // detected, confirmed, false_alarm
  resolvedAt    DateTime?
  notes         String?

  @@index([userId, detectedAt])
  @@map("crash_events")
}

// Feature 8: Lean Angle tracking data
model LeanAngleSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  rideId      String?                     // optional link to ride
  maxLeanLeft Float    @default(0)         // degrees
  maxLeanRight Float   @default(0)         // degrees
  avgLean     Float    @default(0)         // degrees
  dataPoints  String                      // JSON: [{timestamp, lean, speed}]
  duration    Int      @default(0)         // seconds
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("lean_angle_sessions")
}

// Feature 11: GPX Import/Export history
model GpxImport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fileName    String
  fileSize    Int      @default(0)         // bytes
  routeCount  Int      @default(0)
  trackCount  Int      @default(0)
  status      String   @default("processing") // processing, completed, failed
  resultData  String?  // JSON: summary of imported data
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("gpx_imports")
}

// Feature 12: Challenges & Competitions
model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // distance, rides, elevation, speed, streak, custom
  goal        Float                      // target value (km, count, meters, etc.)
  unit        String   // km, rides, m, days
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean  @default(true)
  category    String   @default("monthly") // weekly, monthly, seasonal, yearly, special
  icon        String   @default("🏆")
  points      Int      @default(100)       // gamification points reward
  creatorId   String?
  creator     User?    @relation(fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())

  participants ChallengeParticipant[]

  @@index([startDate, endDate])
  @@index([isPublic])
  @@map("challenges")
}

model ChallengeParticipant {
  id           String   @id @default(cuid())
  challengeId  String
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  progress     Float    @default(0)         // current progress value
  completed    Boolean  @default(false)
  completedAt  DateTime?
  pointsEarned Int      @default(0)
  joinedAt     DateTime @default(now())

  @@unique([challengeId, userId])
  @@index([userId])
  @@map("challenge_participants")
}

// Feature 15: Map Styles (user preferences)
model MapStyleConfig {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  styleName   String   @default("streets") // streets, satellite, terrain, dark, topo, osm
  customUrl   String?  // custom tile server URL
  overlayTraffic Boolean @default(false)
  overlayWeather Boolean @default(false)
  overlayHazards Boolean @default(true)
  overlayPois Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId])
  @@map("map_style_configs")
}

// Feature 16: Service/Dealer Locator
model ServiceCenter {
  id          String   @id @default(cuid())
  name        String
  type        String   // dealer, mechanic, tire_shop, parts, washing, inspection
  brand       String?  // brand affiliation (BMW, Honda, Yamaha, etc.)
  lat         Float
  lng         Float
  address     String?
  phone       String?
  website     String?
  rating      Float    @default(0)
  services    String?  // JSON: array of offered services
  hours       String?  // JSON: opening hours
  createdAt   DateTime @default(now())

  @@index([lat, lng])
  @@index([type])
  @@map("service_centers")
}

// Feature 17: Gamification Points
model UserPoints {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  totalPoints     Int      @default(0)
  level           Int      @default(1)
  ridesPoints     Int      @default(0)   // points from rides
  socialPoints    Int      @default(0)   // points from social activities
  challengePoints Int      @default(0)   // points from challenges
  streakDays      Int      @default(0)   // consecutive riding days
  lastRideDate    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId])
  @@index([totalPoints])
  @@map("user_points")
}

model PointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Int                        // positive = earn, negative = spend
  reason      String   // ride_completed, challenge_won, social_share, etc.
  relatedId   String?  // ID of related entity (ride, challenge, etc.)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@map("points_transactions")
}

// Feature: Favorites/Bookmarks - save routes & rides for later
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  rideId     String?
  ride       Ride?    @relation(fields: [rideId], references: [id], onDelete: Cascade)
  routeId    String?
  route      Route?   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, rideId, routeId])
  @@index([userId])
  @@map("favorites")
}

// Feature: Social Feed - activity stream
model SocialActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // ride_completed, route_shared, achievement_earned, challenge_joined, community_joined, group_ride_created, comment_posted, photo_uploaded
  title       String
  description String?
  icon        String   @default("🏍️")
  targetId    String?  // ID of the related entity
  targetType  String?  // ride, route, achievement, challenge, community, group_ride
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  likes       ActivityLike[]

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("social_activities")
}

model ActivityLike {
  id           String   @id @default(cuid())
  userId       String
  activityId   String
  activity     SocialActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, activityId])
  @@map("activity_likes")
}

// Feature 2: Offline Maps - persisted download status
model OfflineMap {
  id            String   @id @default(cuid())
  regionId      String   @unique              // maps to the region identifier (e.g. "slovenia-full")
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  downloadedAt  DateTime @default(now())

  @@index([userId])
  @@map("offline_maps")
}

// Privacy Zones - geofenced areas to hide from ride tracks
model PrivacyZone {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String                      // e.g. "Dom", "Služba"
  lat         Float                       // center latitude
  lng         Float                       // center longitude
  radiusMeters Int     @default(200)      // radius in meters
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("privacy_zones")
}

// Balkan Moto Events - motorcycle events across the Balkans
model MotoEvent {
  id            String   @id @default(cuid())
  title         String
  description   String?
  date          DateTime                    // event start date
  endDate       DateTime?                   // event end date (for multi-day)
  lat           Float
  lng           Float
  location      String                      // location name
  country       String                      // SI, HR, BA, RS, ME, MK, AL, BG, RO, GR, TR, HU, AT
  category      String   @default("meet")   // meet, rally, race, show, charity, tour, festival
  website       String?                     // event website URL
  imageUrl      String?                     // event image/poster
  organizerName String?                      // organizer name
  contactEmail  String?                      // contact email
  isFeatured    Boolean  @default(false)     // featured event
  isPublic      Boolean  @default(true)
  createdBy     String?                      // userId of creator
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([country])
  @@index([category])
  @@map("moto_events")
}

// Camp Site - Balkan camping locations for moto travelers
model CampSite {
  id          String   @id @default(cuid())
  name        String
  description String?
  lat         Float
  lng         Float
  country     String                      // SI, HR, BA, RS, ME, MK, AL, BG, RO, GR, TR, HU, AT
  address     String?
  phone       String?
  website     String?
  email       String?
  rating      Float    @default(0)
  priceRange  String?                      // budget, mid, premium
  amenities   String?                      // JSON: array of amenities (wifi, showers, kitchen, etc.)
  motoFriendly Boolean @default(true)       // motorcycle-friendly
  openSeason  String?                      // e.g. "Apr-Oct", "All year"
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lat, lng])
  @@index([country])
  @@map("camp_sites")
}
