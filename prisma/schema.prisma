generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  bike      String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rides        Ride[]
  routes       Route[]
  comments     Comment[]
  likes        Like[]
  pois         Poi[]
  achievements Achievement[]
  communities CommunityMember[]
  hazards     Hazard[]
}

model Ride {
  id          String   @id @default(cuid())
  title       String
  description String?
  distance    Float    @default(0)
  duration    Int      @default(0)    // seconds
  avgSpeed    Float    @default(0)    // km/h
  maxSpeed    Float    @default(0)    // km/h
  elevation   Float    @default(0)    // meters gained
  isPublic    Boolean  @default(true)
  isLive      Boolean  @default(false)
  trackData   String                  // JSON: array of [lat, lng, alt, timestamp]
  startLat    Float?
  startLng    Float?
  endLat      Float?
  endLng      Float?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id])
}

model Route {
  id          String   @id @default(cuid())
  title       String
  description String?
  distance    Float    @default(0)
  waypoints   String                 // JSON: array of {lat, lng}
  routeData   String?                // JSON: full polyline coordinates
  category    String   @default("scenic") // scenic, twisty, offroad, city
  difficulty  String   @default("medium") // easy, medium, hard
  isPublic    Boolean  @default(true)
  likes       Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
  likesRel    Like[]
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rideId    String?
  ride      Ride?    @relation(fields: [rideId], references: [id])
  routeId   String?
  route     Route?   @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, routeId])
}

model Poi {
  id          String   @id @default(cuid())
  name        String
  type        String   // gas_station, restaurant, biker_spot, parking, hotel, mechanic
  lat         Float
  lng         Float
  description String?
  rating      Float    @default(0)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  type        String   // achievement type key
  title       String
  description String
  icon        String   // emoji
  earnedAt    DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  avatar      String?    // emoji or icon
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     CommunityMember[]
  rides       Ride[]
}

model CommunityMember {
  id          String   @id @default(cuid())
  role        String   @default("member")  // admin, moderator, member
  joinedAt    DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  communityId String
  community   Community @relation(fields: [communityId], references: [id])

  @@unique([userId, communityId])
}

model Hazard {
  id          String   @id @default(cuid())
  type        String   // speed_camera, rockfall, slippery, wildlife, construction, speed_limit, accident
  name        String
  description String?
  lat         Float
  lng         Float
  expiresAt   DateTime?  // when the hazard is no longer valid
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}
